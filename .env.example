# Copy this file to ".env" and fill in your key.
# Used ONLY by the data-collection scripts (courts.py, pools.py) — never by the
# website. .env is git-ignored, so your key is never committed or deployed.
#
# Requires a Google Maps key with the "Places API (New)" enabled:
#   https://console.cloud.google.com/  ->  APIs & Services  ->  Places API (New)
GOOGLE_MAPS_API_KEY=your-key-here
